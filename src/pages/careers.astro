---
import Base from '../layouts/Base.astro';
---

<Base
  title="Careers — Restoration Medical"
  description="Join Restoration Medical. We're building a physician-led institution of six institutes, held to one standard of care."
>
  <section class="section-tight">
    <div class="wrap">
      <header class="page-header reveal">
        <span class="eyebrow">Careers</span>
        <h1 class="page-header__title ripple">Build the standard with us.</h1>
        <p class="page-header__lead">
          We’re assembling clinicians and staff who want to practise honestly — screened-first care,
          physician oversight, and outcomes we can stand behind. If that’s you, we’d like to talk.
        </p>
        <div class="hero__actions" style="display:flex; gap:0.8rem; flex-wrap:wrap; margin-top:1.8rem">
          <a class="btn btn--lg" href="/contact">Introduce yourself</a>
          <a class="btn btn--ghost btn--lg" href="/about">About the institution</a>
        </div>
      </header>

      <div class="advisory reveal" style="margin-top:2.5rem">
        <span class="advisory__badge" aria-hidden="true">i</span>
        <p class="advisory__body">
          <strong>No open roles listed yet.</strong> Send the positions you’re hiring for and we’ll
          publish them here with an application flow.
        </p>
      </div>
    </div>
  </section>
</Base>
