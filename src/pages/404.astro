---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — Restoration Medical" description="The page you were looking for could not be found.">
  <section class="section">
    <div class="wrap-narrow cta-band">
      <span class="eyebrow">404</span>
      <h1 class="cta-band__title">We couldn’t find that page.</h1>
      <p class="cta-band__body">
        The link may have moved. Head back to the start, or jump straight to one of our divisions.
      </p>
      <div class="cta-band__actions">
        <a class="btn btn--lg" href="/">Back to home</a>
        <a class="btn btn--ghost btn--lg" href="/medical-aesthetics">Medical Aesthetics</a>
        <a class="btn btn--ghost btn--lg" href="/infusion-therapy">Infusion Therapy</a>
      </div>
    </div>
  </section>
</Base>
