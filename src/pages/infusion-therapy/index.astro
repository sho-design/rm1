---
import InfusionLayout from '../../layouts/InfusionLayout.astro';

const ip = (p: string) => `/infusion-therapy${p}`;
const BOOK = '/contact';

const concerns = [
  { href: ip('/concerns/low-energy-fatigue'), accent: '#5A57A6', label: 'Low energy & fatigue', line: 'Running low more often than you would like.', d: 'M13 2 5 13h5l-1 9 9-12h-5l1-8z', more: 'Explore →' },
  { href: ip('/concerns/immune-support'), accent: '#2E8A66', label: 'Immune support', line: 'Bracing for a demanding season.', d: 'M12 3l7 3v5.5c0 4.2-2.9 7.4-7 8.9-4.1-1.5-7-4.7-7-8.9V6z', more: 'Explore →' },
  { href: ip('/concerns/skin-hair-nails'), accent: '#C2598E', label: 'Skin, hair & nails', line: 'Caring for how you look from within.', d: 'M12 3c.9 3.9 2.4 5.4 6 6-3.6.9-5.1 2.4-6 6-.9-3.6-2.4-5.1-6-6 3.6-.9 5.1-2.4 6-6z', more: 'Explore →' },
  { href: ip('/concerns/recovery-performance'), accent: '#2C72C4', label: 'Recovery & performance', line: 'Training hard and recovering harder.', d: 'M3 12h4l2.5-6 4 12 2.5-6H21', more: 'Explore →' },
  { href: ip('/concerns/longevity'), accent: '#8A57A2', label: 'Longevity & healthy aging', line: 'Investing in how you age.', d: 'M7 3h10l-5 9 5 9H7l5-9z', more: 'Explore →' },
  { href: ip('/concerns/weight-metabolism'), accent: '#B05741', label: 'Weight & metabolism', line: 'Working toward a goal, with support.', d: 'M12 3c3 3.4 5 6 5 9a5 5 0 0 1-10 0c0-1.7.8-3 2-4 .3 1 .9 1.7 1.8 2 .6-2.4-.4-4.7 1.2-7z', more: 'Explore →' },
  { href: ip('/iron-therapy'), accent: '#B23A4F', label: 'Iron deficiency & low ferritin', line: 'When fatigue may be about iron.', d: 'M12 3c3.5 5 6 7.5 6 10.5a6 6 0 0 1-12 0C6 10.5 8.5 8 12 3z', more: 'Clinical pathway →' },
  { href: ip('/concerns/hydration-travel'), accent: '#1B8794', label: 'Hydration & travel', line: 'Resetting after the road.', d: 'M21 3 3 10.5l7 2.6L12.6 21 21 3z', more: 'Explore →' },
];

const drips = [
  { href: ip('/drips/healing'), family: 'Foundation & Healing', accent: 'var(--accent-wellness)', text: '#33505F', name: "Healing (Myers')", essence: 'A classic blend to support energy and immune recovery.', dots: 5 },
  { href: ip('/drips/radiance'), family: 'Radiance & Beauty', accent: 'var(--accent-radiance)', text: '#8D5E82', name: 'Radiance', essence: 'Antioxidant and skin-radiance support.', dots: 3 },
  { href: ip('/drips/immune-shield'), family: 'Immune', accent: 'var(--accent-immune)', text: '#A55B2C', name: 'Immune Shield', essence: 'Seasonal immune defence.', dots: 4 },
  { href: ip('/drips/nad-longevity'), family: 'Energy & Longevity', accent: 'var(--accent-energy)', text: '#8F7212', name: 'NAD+ Longevity', essence: 'Cellular energy and healthy-aging support.', dots: 3 },
  { href: ip('/drips/beauty-elixir'), family: 'Radiance & Beauty', accent: 'var(--accent-radiance)', text: '#8D5E82', name: 'Beauty Elixir', essence: 'Complete beauty-from-within support.', dots: 5 },
  { href: ip('/drips/metabolic'), family: 'Metabolic', accent: 'var(--accent-metabolic)', text: '#566F46', name: 'Metabolic', essence: 'Fat-metabolism support within a guided program.', dots: 4 },
  { href: ip('/drips/kingmaker'), family: 'Energy & Longevity', accent: 'var(--accent-energy)', text: '#8F7212', name: 'Kingmaker', essence: 'Vitality support for men.', dots: 4 },
  { href: ip('/drips/pregnancy-care'), family: 'Foundation & Healing', accent: 'var(--accent-wellness)', text: '#33505F', name: 'Pregnancy Care', essence: 'Gentle, physician-supervised hydration and nutrient support through pregnancy.', dots: 5 },
];

const steps = [
  { n: '01', t: 'Consult & screen', d: 'We talk through how you want to feel and review your health, so any treatment is safe and right for you.' },
  { n: '02', t: 'Personalize your treatment', d: 'Our physician reviews and our nurse tailors the drip or shot to you. No fixed menu, no pressure.' },
  { n: '03', t: 'Relax while we care for you', d: 'Settle into the chair in a calm clinical setting. We stay with you from the first drop to the last.' },
];

const trust = [
  { h: 'Physician oversight', d: 'Every treatment is reviewed by our physician, not sold from a counter.' },
  { h: 'RN administration', d: 'Your infusion is placed and monitored by a registered nurse.' },
  { h: 'Honest screening', d: 'We screen first, and we will adjust or decline on clinical grounds.' },
  { h: 'Sourcing standards', d: 'Pharmaceutical-grade ingredients, prepared to clinical standards.' },
];
---

<InfusionLayout>
  <section class="hero">
    <div class="hero__bag in-load" style="--load-delay: 220ms" aria-hidden="true">
      <div class="hero__bag-body">
        <canvas class="hero__bag-canvas" data-hero-fluid></canvas>
      </div>
      <svg class="hero__bag-frame" viewBox="0 0 128 184" fill="none" aria-hidden="true">
        <path class="hero__bag-outline" d="M24 8 L104 8 Q120 8 120 24 L120 108 Q120 118 111 121 L72 134 L72 146 L56 146 L56 134 L17 121 Q8 118 8 108 L8 24 Q8 8 24 8 Z" />
        <rect class="hero__bag-outline" x="51" y="146" width="26" height="12" rx="3" />
        <path class="hero__bag-outline" d="M58 158 L70 158 L66.5 178 L61.5 178 Z" />
        <rect class="hero__bag-hole" x="47" y="17" width="34" height="11" rx="5.5" />
        <ellipse class="hero__bag-port" cx="105" cy="46" rx="3.6" ry="6.2" />
        <ellipse class="hero__bag-port" cx="105" cy="62" rx="3.6" ry="6.2" />
      </svg>
    </div>
    <div class="wrap hero__inner">
      <p class="eyebrow hero__eyebrow in-load">Infusion Therapy · Refined by Medicine</p>
      <h1 class="hl hero__title ripple in-load" style="--load-delay: 90ms">
        <span class="lg">Come as you are.</span>
        <span class="lg"><span class="it">Leave feeling restored.</span></span>
      </h1>
      <p class="lead hero__lead in-load" style="--load-delay: 180ms">
        From everyday energy to clinically indicated iron infusions, our therapies meet your body
        where it is and help you feel like yourself again. Reviewed by our physician, given by our
        nurses.
      </p>
      <div class="hero__actions in-load" style="--load-delay: 260ms">
        <a class="btn btn--lg" href={BOOK}>Book a consult</a>
        <a class="link-arrow" href={ip('/drips')}>Explore drips &amp; shots &rarr;</a>
      </div>
    </div>
    <div class="wrap hero__meta in-load" style="--load-delay: 340ms">
      <span class="meta">Physician-reviewed</span>
      <span class="hero__sep" aria-hidden="true"></span>
      <span class="meta">Nurse-administered</span>
      <span class="hero__sep" aria-hidden="true"></span>
      <span class="meta">Thornhill &amp; Maple (Coming Soon)</span>
    </div>
  </section>

  <section class="section fill">
    <div class="wrap">
      <div class="reveal sec-head">
        <p class="eyebrow">Two paths, one standard of care</p>
        <h2 class="hl display-3">Wellness <span class="it">and</span> clinical, under one roof.</h2>
      </div>
      <div class="paths reveal">
        <article class="path">
          <h3 class="path__title">Wellness infusions &amp; shots</h3>
          <p class="path__body">
            Support energy, immunity, skin, recovery, and healthy aging. Personalized to you, given
            in a calm clinical setting. Elective, and designed around how you want to feel.
          </p>
          <a class="link-arrow" href={ip('/drips')}>Browse drips &amp; shots &rarr;</a>
        </article>
        <article class="path">
          <h3 class="path__title">Clinical infusions</h3>
          <p class="path__body">
            Including iron therapy for low ferritin and iron deficiency. Lab-reviewed and
            physician-directed, for when your body needs more than supplements can give.
          </p>
          <a class="link-arrow" href={ip('/iron-therapy')}>See iron therapy &rarr;</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="reveal sec-head">
        <p class="eyebrow">Find your starting point</p>
        <h2 class="hl display-3">Start with how you feel.</h2>
        <p class="lead">
          Tell us how you want to feel. We will help you find the right support. Most people arrive
          with a feeling, not a product name.
        </p>
      </div>
      <div class="concern-grid reveal">
        {
          concerns.map((c) => (
            <a class="tile" href={c.href} style={`--accent:${c.accent}`}>
              <span class="tile__icon" aria-hidden="true">
                <svg class="cicon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style={`color:${c.accent}`}>
                  <path d={c.d} />
                </svg>
              </span>
              <span class="tile__label">{c.label}</span>
              <span class="tile__line">{c.line}</span>
              <span class="tile__more link-arrow">{c.more}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section fill">
    <div class="wrap">
      <div class="reveal sec-head">
        <p class="eyebrow">Browse our drips &amp; shots</p>
        <h2 class="hl display-3">The page is quiet. <span class="it">The menu blooms.</span></h2>
        <p class="lead">
          Each treatment family carries its own accent, drawn from its ingredients. A considered
          apothecary, not a rainbow.
        </p>
      </div>
      <div class="drip-grid reveal">
        {
          drips.map((d) => (
            <a class="dcard" href={d.href} style={`--accent: ${d.accent}; --accent-text: ${d.text}`}>
              <span class="dcard__rule" aria-hidden="true"></span>
              <span class="dcard__top">
                <span class="dcard__family">{d.family}</span>
                <span class="dcard__type">Drip</span>
              </span>
              <span class="dcard__name">{d.name}</span>
              <span class="dcard__essence">{d.essence}</span>
              <span class="dcard__dots" aria-hidden="true">
                {Array.from({ length: d.dots }).map(() => <span class="dcard__dot"></span>)}
              </span>
              <span class="dcard__more link-arrow">Learn more &rarr;</span>
            </a>
          ))
        }
      </div>
      <div class="reveal more-row">
        <a class="btn btn--ghost" href={ip('/drips')}>See all drips</a>
        <a class="link-arrow" href={ip('/shots')}>Visit the Injection Bar &rarr;</a>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="wrap">
      <figure class="pq reveal">
        <span class="pq__mark" aria-hidden="true">&ldquo;</span>
        <blockquote class="pq__q ripple">Nothing in the bag we cannot explain.</blockquote>
        <figcaption class="pq__cite">Refined by Medicine</figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="wrap trust">
      <div class="reveal trust__intro">
        <p class="eyebrow">Why physician-led matters</p>
        <h2 class="hl display-3">A real clinic, <span class="it">not a drip bar.</span></h2>
        <p class="lead">
          The difference is quiet but it is everything. Screening, real medical oversight, and
          nurses who do this every day.
        </p>
      </div>
      <ul class="trust__list reveal">
        {
          trust.map((t) => (
            <li>
              <p class="trust__h">{t.h}</p>
              <p class="trust__d">{t.d}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section fill">
    <div class="wrap">
      <div class="reveal sec-head">
        <p class="eyebrow">How it works</p>
        <h2 class="hl display-3">Three quiet steps.</h2>
      </div>
      <ol class="steps reveal">
        {
          steps.map((s) => (
            <li class="step">
              <span class="step__n meta tnum">{s.n}</span>
              <h3 class="step__t">{s.t}</h3>
              <p class="step__d">{s.d}</p>
            </li>
          ))
        }
      </ol>
      <div class="reveal more-row">
        <a class="link-arrow" href={ip('/how-it-works')}>Read what to expect &rarr;</a>
      </div>
    </div>
  </section>

  <section class="band reveal">
    <div class="wrap band__inner">
      <p class="eyebrow band__eyebrow">Begin</p>
      <h2 class="hl band__heading display-3">Care that begins with you.</h2>
      <p class="band__body measure">
        Wellness or clinical, the standard of care is the same. A consult confirms what is right for
        you. No pricing surprises, no pressure.
      </p>
      <div class="band__actions">
        <a class="btn btn--lg" href={BOOK}>Book a consult</a>
        <a class="link-arrow" href={ip('/safety')}>Is this right for me? &rarr;</a>
      </div>
      <p class="band__loc meta">Thornhill · Maple (Coming Soon)</p>
    </div>
  </section>

  <style>
    /* Utilities the IT pages rely on (display type, leads, arrow links). */
    .hl { font-family: var(--display); line-height: 1.04; letter-spacing: -0.015em; }
    .hl .it { font-style: italic; font-weight: 340; }
    .hl .lg { display: block; }
    .display-3 { font-size: var(--step-3); }
    .lead { font-size: var(--step-1); color: var(--graphite); line-height: 1.45; max-width: var(--measure); }
    .measure { max-width: var(--measure); }
    .tnum { font-variant-numeric: tabular-nums; }
    .link-arrow {
      font-family: var(--label); font-size: var(--step--1); letter-spacing: 0.04em;
      border-bottom: 1px solid var(--line); padding-bottom: 2px;
      transition: border-color 0.25s var(--ease); white-space: nowrap;
    }
    .link-arrow:hover { border-color: var(--ink); }
    .in-load { opacity: 0; transform: translateY(14px); animation: inLoad 0.8s var(--ease) forwards; animation-delay: var(--load-delay, 0ms); }
    @keyframes inLoad { to { opacity: 1; transform: none; } }
    @media (prefers-reduced-motion: reduce) {
      .in-load { opacity: 1; transform: none; animation: none; }
    }

    /* Hero with the living IV bag */
    .hero { position: relative; overflow: hidden; padding-block: clamp(3.5rem, 8vh, 7rem) var(--space-l); }
    .hero__inner, .hero__meta { position: relative; z-index: 2; }
    .hero__bag { position: absolute; z-index: 1; top: 50%; right: clamp(0.5rem, 5vw, 5rem); transform: translateY(-50%); width: clamp(196px, 22vw, 280px); aspect-ratio: 128 / 184; pointer-events: none; }
    .hero__bag-body { position: absolute; inset: 7.5% 11% 39%; border-radius: 13px 13px 10px 10px; background: color-mix(in srgb, var(--cloud) 50%, transparent); overflow: hidden; }
    .hero__bag-canvas { position: absolute; inset: 0; width: 100%; height: 100%; mix-blend-mode: multiply; -webkit-mask-image: linear-gradient(to top, #000 0 80%, transparent 100%); mask-image: linear-gradient(to top, #000 0 80%, transparent 100%); }
    .hero__bag-frame { position: absolute; inset: 0; width: 100%; height: 100%; overflow: visible; }
    .hero__bag-outline { fill: none; stroke: color-mix(in srgb, var(--graphite) 38%, var(--line)); stroke-width: 1.5; stroke-linejoin: round; stroke-linecap: round; }
    .hero__bag-hole { fill: var(--paper); stroke: color-mix(in srgb, var(--graphite) 38%, var(--line)); stroke-width: 1.5; }
    .hero__bag-port { fill: color-mix(in srgb, var(--accent-recovery) 70%, var(--paper)); }
    @media (min-width: 1000px) { .hero__inner, .hero__meta { padding-right: clamp(270px, 27vw, 380px); } }
    @media (max-width: 999px) { .hero__bag { right: clamp(-70px, -4vw, -20px); opacity: 0.28 !important; width: clamp(190px, 40vw, 260px); } }
    .hero__eyebrow { margin-bottom: 2rem; }
    .hero__title { font-size: var(--step-5); max-width: 16ch; }
    .hero__lead { margin-top: 2rem; font-size: var(--step-1); }
    .hero__actions { margin-top: 2.5rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
    .hero__meta { margin-top: 3.5rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; border-top: 1px solid var(--line); padding-top: 1.5rem; }
    .hero__sep { width: 4px; height: 4px; border-radius: 50%; background: var(--line); }

    .sec-head { max-width: 60ch; margin-bottom: var(--space-m); display: grid; gap: 1rem; }
    .paths { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .path { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); padding: 2.2rem 2rem; display: grid; gap: 1rem; align-content: start; }
    .path__title { font-size: var(--step-2); }
    .path__body { color: var(--graphite); }

    .concern-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; }
    .tile { display: grid; gap: 0.5rem; align-content: start; padding: 1.6rem 1.4rem; background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); position: relative; overflow: hidden; transition: transform 0.3s var(--ease), border-color 0.3s var(--ease), box-shadow 0.3s var(--ease); }
    .tile:before { content: ""; position: absolute; inset: 0 auto 0 0; width: 3px; background: var(--accent); opacity: 0.85; }
    .tile:hover { transform: translateY(-3px); border-color: color-mix(in srgb, var(--accent) 40%, var(--line)); box-shadow: 0 24px 44px -34px #1a1b1d4d; }
    .tile__icon { width: 30px; height: 30px; }
    .tile__label { font-family: var(--display); font-size: var(--step-1); }
    .tile__line { color: var(--mist); font-size: var(--step--1); }
    .tile__more { margin-top: 0.6rem; color: var(--accent-text, var(--ink)); border: 0; padding: 0; }

    .drip-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.2rem; }
    .dcard { position: relative; display: grid; gap: 0.55rem; align-content: start; background-color: var(--white-pure); background-image: var(--gloss-white), var(--sparkle); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.8rem 1.6rem 1.6rem; overflow: hidden; isolation: isolate; transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease); }
    .dcard__rule { position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--accent); }
    .dcard:hover { transform: translateY(-4px); box-shadow: 0 28px 50px -34px #1a1b1d4d; border-color: color-mix(in srgb, var(--accent) 35%, var(--line)); }
    .dcard__top { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
    .dcard__family { font-family: var(--label); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent-text); }
    .dcard__type { font-family: var(--label); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--mist); }
    .dcard__name { font-family: var(--display); font-size: var(--step-2); }
    .dcard__essence { color: var(--graphite); font-size: var(--step--1); }
    .dcard__dots { display: inline-flex; gap: 5px; margin-top: 0.3rem; }
    .dcard__dot { width: 6px; height: 6px; border-radius: 50%; background: color-mix(in srgb, var(--accent) 55%, var(--line)); }
    .dcard__more { margin-top: 0.8rem; color: var(--accent-text); border: 0; padding: 0; }
    .more-row { margin-top: 2rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }

    .pq { text-align: center; display: grid; gap: 0.6rem; padding-block: var(--space-m); }
    .pq__mark { font-family: var(--display); font-size: 3rem; line-height: 0.5; color: var(--accent); }
    .pq__q { font-family: var(--display); font-weight: 360; font-size: var(--step-4); line-height: 1.14; max-width: 22ch; margin: 0 auto; }
    .pq__cite { font-family: var(--label); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.16em; color: var(--mist); }

    .trust { display: grid; grid-template-columns: 1fr 1.1fr; gap: 3rem; align-items: start; }
    .trust__intro { display: grid; gap: 1rem; position: sticky; top: calc(var(--header-h) + 2rem); }
    .trust__list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem 2rem; }
    .trust__h { font-family: var(--display); font-size: var(--step-1); margin-bottom: 0.4rem; }
    .trust__d { color: var(--graphite); font-size: var(--step--1); }

    .steps { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .step { border-top: 1px solid var(--ink); padding-top: 1.2rem; display: grid; gap: 0.7rem; }
    .step__t { font-size: var(--step-2); }
    .step__d { color: var(--graphite); }

    .band { background: var(--surface-dark); color: var(--on-dark); padding-block: var(--space-xl); }
    .band__inner { display: grid; gap: 1.2rem; justify-items: start; }
    .band .eyebrow { color: color-mix(in srgb, var(--on-dark) 60%, transparent); }
    .band__heading { font-size: var(--step-3); }
    .band__body { color: color-mix(in srgb, var(--on-dark) 80%, transparent); }
    .band__actions { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; margin-top: 0.6rem; }
    .band__actions .btn { --btn-bg: var(--on-dark); --btn-fg: var(--surface-dark); border-color: var(--on-dark); }
    .band__actions .link-arrow { color: var(--on-dark); border-color: color-mix(in srgb, var(--on-dark) 40%, transparent); }
    .band__loc { color: color-mix(in srgb, var(--on-dark) 55%, transparent); }

    @media (max-width: 820px) {
      .paths, .trust, .trust__list, .steps { grid-template-columns: 1fr; }
      .trust__intro { position: static; }
    }
  </style>

  <script>
    // Living IV bag: colour "ingredients" drift up from the bottom port.
    // Ported from the Infusion Therapy site.
    const init = () => {
      const c = document.querySelector('[data-hero-fluid]');
      if (!(c instanceof HTMLCanvasElement) || c.dataset.init === '1') return;
      const a = c.getContext('2d');
      if (!a) return;
      c.dataset.init = '1';
      const palette = ['#3e5c6e', '#b98aae', '#c2703d', '#c9a227', '#6e8b5a', '#4f7c82', '#0e9bc9', '#c65f73', '#3e4c8a'];
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const rand = (t: number, e: number) => t + Math.random() * (e - t);
      let w = 0, h = 0, raf = 0, frame = 0, shift = Math.random() * 9;
      const blobs: any[] = [];
      const resize = () => {
        const r = c.getBoundingClientRect();
        w = r.width; h = r.height;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        c.width = Math.max(1, Math.round(w * dpr));
        c.height = Math.max(1, Math.round(h * dpr));
        a.setTransform(dpr, 0, 0, dpr, 0, 0);
      };
      const spawn = () => {
        blobs.push({ x: w * rand(0.18, 0.82), y: h + 10, vy: -rand(0.03, 0.09), drift: rand(-0.5, 0.5), phase: rand(0, Math.PI * 2), r: rand(w * 0.1, w * 0.17), grow: rand(0.02, 0.05), life: 0, ttl: rand(900, 1400), color: palette[Math.floor(Math.random() * palette.length)] });
      };
      const draw = (b: any, alpha: number) => {
        const g = a.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r);
        g.addColorStop(0, b.color); g.addColorStop(1, 'rgba(255,255,255,0)');
        a.globalAlpha = alpha; a.fillStyle = g; a.beginPath(); a.arc(b.x, b.y, b.r, 0, Math.PI * 2); a.fill();
      };
      const wash = () => {
        shift += 9e-4;
        const t = Math.floor(shift) % palette.length, e = shift % 1;
        const g = a.createLinearGradient(0, h, 0, h * 0.18);
        g.addColorStop(0, palette[t]); g.addColorStop(1, 'rgba(255,255,255,0)');
        a.globalAlpha = 0.14; a.fillStyle = g; a.fillRect(0, 0, w, h);
        const g2 = a.createLinearGradient(0, h, 0, h * 0.32);
        g2.addColorStop(0, palette[(t + 1) % palette.length]); g2.addColorStop(1, 'rgba(255,255,255,0)');
        a.globalAlpha = 0.1 * e; a.fillStyle = g2; a.fillRect(0, 0, w, h);
      };
      const tick = () => {
        a.clearRect(0, 0, w, h); wash();
        for (let i = blobs.length - 1; i >= 0; i--) {
          const b = blobs[i];
          b.life++; b.y += b.vy; b.x += Math.sin(b.life * 0.007 + b.phase) * 0.4 + b.drift * 0.01; b.r += b.grow;
          const p = b.life / b.ttl, fade = Math.sin(Math.min(p, 1) * Math.PI);
          draw(b, Math.max(0, fade) * 0.45);
          if (p >= 1 || b.y + b.r < -20) blobs.splice(i, 1);
        }
        a.globalAlpha = 1;
        if (frame % 72 === 0 && blobs.length < 10) spawn();
        frame++; raf = requestAnimationFrame(tick);
      };
      resize();
      window.addEventListener('resize', resize);
      if (reduce) {
        wash();
        for (let i = 0; i < 4; i++) draw({ x: w * rand(0.25, 0.75), y: h * rand(0.5, 0.92), r: w * rand(0.12, 0.2), color: palette[i % palette.length] }, 0.5);
        a.globalAlpha = 1;
        return;
      }
      for (let i = 0; i < 5; i++) { spawn(); const b = blobs[blobs.length - 1]; b.life = i * 90; b.y = h * rand(0.45, 0.95); }
      raf = requestAnimationFrame(tick);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) { cancelAnimationFrame(raf); raf = 0; } else if (!raf) raf = requestAnimationFrame(tick);
      });
    };
    document.readyState !== 'loading' ? init() : document.addEventListener('DOMContentLoaded', init);
  </script>
</InfusionLayout>
