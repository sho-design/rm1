---
import Base from '../layouts/Base.astro';

const principles = [
  {
    title: 'Screened first',
    body: 'Every patient is assessed before any treatment is offered. If something is not right for you, we say so — and we say why.',
  },
  {
    title: 'Physician oversight',
    body: 'A physician reviews care across every institute. Clinicians deliver; the counter never finalises a treatment.',
  },
  {
    title: 'Honest about evidence',
    body: 'We rate what we offer as established or emerging, and set expectations plainly. Results vary — and we tell you so.',
  },
  {
    title: 'One record of care',
    body: 'Move between institutes and your history moves with you. One institution means one coordinated picture of your health.',
  },
];
---

<Base
  title="About — Restoration Medical"
  description="Restoration Medical is one physician-led institution of six institutes, held to a single clinical standard: screened first, physician-overseen, honest about evidence."
>
  <section class="section-tight">
    <div class="wrap">
      <header class="page-header reveal">
        <span class="eyebrow">About the institution</span>
        <h1 class="page-header__title ripple">One institution. <span class="it">One standard.</span></h1>
        <p class="page-header__lead">
          Restoration Medical is a single, physician-led institution. Its institutes — family
          medicine, pain medicine, medical aesthetics, rehabilitation, performance medicine, and
          infusion therapy — each run as their own world, but answer to the same standard of care.
        </p>
      </header>
    </div>
  </section>

  <section id="standard" class="section-tight fill">
    <div class="wrap">
      <header class="section-head reveal">
        <span class="eyebrow">How we practise</span>
        <h2>Four commitments, held everywhere.</h2>
      </header>
      <div class="grid grid--cards reveal" style="margin-top:2.5rem">
        {
          principles.map((p) => (
            <article class="card">
              <h3 class="card__name">{p.title}</h3>
              <p class="card__essence">{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <figure class="pullquote reveal">
    <div class="pullquote__rule"></div>
    <blockquote class="pullquote__text ripple">Different worlds. One standard of care.</blockquote>
    <figcaption class="pullquote__cite">The institution</figcaption>
  </figure>

  <section class="section-tight">
    <div class="wrap-narrow cta-band reveal">
      <h2 class="cta-band__title">Meet the people behind it.</h2>
      <p class="cta-band__body">
        The standard only means something because of who keeps it. Get to know the physicians and
        clinicians across the institution.
      </p>
      <div class="cta-band__actions">
        <a class="btn btn--lg" href="/physicians">Our physicians</a>
        <a class="btn btn--ghost btn--lg" href="/contact">Book a consult</a>
      </div>
    </div>
  </section>
</Base>
