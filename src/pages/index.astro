---
import Base from '../layouts/Base.astro';
import HeroMotif from '../components/HeroMotif.astro';
import { institutes } from '../data/institutes';
---

<Base
  title="Restoration Medical — Refined by Medicine"
  description="One institution, many worlds of care. Restoration Medical brings six physician-led institutes — family medicine, pain medicine, medical aesthetics, rehabilitation, performance medicine, and infusion therapy — under one roof and one clinical standard."
>
  <section class="section hero">
    <div class="wrap hero__grid">
      <div class="hero__copy">
        <span class="eyebrow">Restoration Medical</span>
        <h1 class="hero__title ripple">One institution. <span class="it">Many worlds of care.</span></h1>
        <p class="lede">
          Six physician-led institutes under one roof. Each its own world — its own clinicians, its
          own focus — held to a single clinical standard. Screened first, honest about the evidence.
        </p>
        <div class="hero__actions">
          <a class="btn btn--lg" href="#institutes">Choose your journey</a>
          <a class="btn btn--ghost btn--lg" href="/about">About the institution</a>
        </div>
        <p class="meta hero__tag">Refined by Medicine.</p>
      </div>
      <div class="hero__motif">
        <HeroMotif />
      </div>
    </div>
  </section>

  <section id="institutes" class="section-tight">
    <div class="wrap">
      <header class="section-head reveal">
        <span class="eyebrow">Choose your journey</span>
        <h2>Six institutes. One institution.</h2>
        <p class="lede">
          Step into any institute and the world changes — the focus, the colour, the clinicians.
          Step back out and you’re still inside one practice, one standard, one record of care.
        </p>
      </header>

      <div class="grid grid--cards reveal" style="margin-top:2.5rem">
        {
          institutes.map((i) => (
            <a
              class="card card--link"
              href={`/${i.slug}`}
              style={`--accent: var(--accent-${i.accent}); --accent-text: var(--accent-${i.accent}-text)`}
            >
              <span class="card__family">Institute</span>
              <h3 class="card__name">{i.name}</h3>
              <p class="card__essence">{i.essence}</p>
              <span class="card__go">
                {i.status === 'live' ? 'Enter' : 'Explore'} {i.name} &rarr;
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <figure class="pullquote reveal">
    <div class="pullquote__rule"></div>
    <blockquote class="pullquote__text ripple">Different worlds. One standard of care.</blockquote>
    <figcaption class="pullquote__cite">The institution</figcaption>
  </figure>

  <section class="section-tight fill">
    <div class="wrap trust reveal">
      <div>
        <span class="eyebrow">The clinic, not the counter</span>
        <h2>Trust is a design feature.</h2>
        <p class="lede">
          Every institute answers to the same physician oversight. We show our evidence rather than
          imply it — and we keep a genuine medical anchor across the whole institution.
        </p>
        <p style="margin-top:1.4rem; display:flex; gap:1.4rem; flex-wrap:wrap; align-items:center">
          <span class="evidence evidence--established" tabindex="0" role="note" aria-label="Established evidence">
            <span class="evidence__dot" aria-hidden="true"></span>Established
            <span class="evidence__tip" role="tooltip">
              Established — supported by consistent, higher-quality clinical evidence and long
              clinical use.
            </span>
          </span>
          <span class="evidence evidence--emerging" tabindex="0" role="note" aria-label="Emerging evidence">
            <span class="evidence__dot" aria-hidden="true"></span>Emerging
            <span class="evidence__tip" role="tooltip">
              Emerging — early or mixed evidence. Promising, but we set expectations honestly and
              results vary.
            </span>
          </span>
        </p>
        <p class="meta" style="margin-top:1rem">Hover the tags — every benefit claim is rated and honest.</p>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="wrap-narrow cta-band reveal">
      <h2 class="cta-band__title">Not sure which institute?</h2>
      <p class="cta-band__body">
        Start with one conversation. We screen first, then point you to the right institute — never
        the other way round.
      </p>
      <div class="cta-band__actions">
        <a class="btn btn--lg" href="/contact">Book a consult</a>
        <a class="btn btn--ghost btn--lg" href="/physicians">Meet the physicians</a>
      </div>
    </div>
  </section>

  <style>
    .hero__grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--space-l);
      align-items: center;
    }
    .hero__title {
      /* Slightly tighter than the institute heroes — this headline is longer,
         so cap the size to avoid mid-word breaks at desktop widths. */
      font-size: clamp(2.6rem, 1.7rem + 3.4vw, 4.6rem);
      margin: 0.4rem 0 1.2rem;
    }
    .hero__actions {
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
      margin-top: 1.8rem;
    }
    .hero__tag {
      margin-top: 1.6rem;
    }
    .section-head h2 {
      font-size: var(--step-3);
    }
    .section-head .lede {
      margin-top: 0.6rem;
    }
    .trust {
      max-width: var(--measure);
    }
    .card--link {
      cursor: pointer;
    }
    .card__go {
      font-family: var(--mono);
      font-size: var(--step--1);
      letter-spacing: 0.04em;
      color: var(--accent-text);
      margin-top: 1.2rem;
    }
    @media (max-width: 900px) {
      .hero__grid {
        grid-template-columns: 1fr;
      }
      .hero__motif {
        order: -1;
      }
    }
  </style>
</Base>
