---
import Base from '../layouts/Base.astro';

const principles = [
  {
    title: 'Screened first',
    body: 'Every patient is assessed before any treatment is offered. If something is not right for you, we say so — and we say why.',
  },
  {
    title: 'Physician oversight',
    body: 'A physician reviews the plan across both divisions. Clinicians deliver care; the counter never finalises a treatment.',
  },
  {
    title: 'Honest about evidence',
    body: 'We rate what we offer as established or emerging, and we set expectations plainly. Results vary — and we tell you so.',
  },
  {
    title: 'Restraint by design',
    body: 'We treat conservatively and aim for outcomes that still look like you. Subtle is the standard, not the exception.',
  },
];
---

<Base
  title="The Practice — Restoration Medical"
  description="How Restoration Medical practises: screened first, physician-led, honest about evidence, and restrained by design — one clinical standard across medical aesthetics and infusion therapy."
>
  <section class="section-tight">
    <div class="wrap">
      <header class="page-header reveal">
        <span class="eyebrow">The practice</span>
        <h1 class="page-header__title ripple">One clinical standard.</h1>
        <p class="page-header__lead">
          Restoration Medical is a single, physician-led practice. Medical Aesthetics and Infusion
          Therapy are two divisions of it — different services, the same standard of care.
        </p>
      </header>
    </div>
  </section>

  <section id="standard" class="section-tight fill">
    <div class="wrap">
      <header class="section-head reveal">
        <span class="eyebrow">How we practise</span>
        <h2>Four commitments, held everywhere.</h2>
      </header>
      <div class="grid grid--cards reveal" style="margin-top:2.5rem">
        {
          principles.map((p) => (
            <article class="card">
              <h3 class="card__name">{p.title}</h3>
              <p class="card__essence">{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <figure class="pullquote reveal">
    <div class="pullquote__rule"></div>
    <blockquote class="pullquote__text ripple">Results vary — and we say so.</blockquote>
    <figcaption class="pullquote__cite">On honesty</figcaption>
  </figure>

  <section class="section-tight">
    <div class="wrap-narrow cta-band reveal">
      <h2 class="cta-band__title">Meet the people behind it.</h2>
      <p class="cta-band__body">
        The standard only means something because of who keeps it. Get to know the clinicians and
        the physician anchor across both divisions.
      </p>
      <div class="cta-band__actions">
        <a class="btn btn--lg" href="/team">Our team</a>
        <a class="btn btn--ghost btn--lg" href="/contact">Book a consult</a>
      </div>
    </div>
  </section>
</Base>
