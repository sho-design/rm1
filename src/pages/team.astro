---
import Base from '../layouts/Base.astro';

// Placeholder roster — replace names, roles, and bios with the real team.
const team = [
  {
    name: 'Medical Director',
    role: 'Physician · Medical oversight',
    bio: 'Reviews and finalises treatment plans across both divisions, with a clinical anchor in dermatology and scar revision.',
  },
  {
    name: 'Lead Aesthetic Clinician',
    role: 'Medical Aesthetics',
    bio: 'Delivers injectables, resurfacing, and energy-based treatments with a conservative, results-honest approach.',
  },
  {
    name: 'Lead Infusion Nurse',
    role: 'Infusion Therapy',
    bio: 'Runs the infusion suite and injection bar, with screening and monitoring at the centre of every visit.',
  },
];
---

<Base
  title="Our Team — Restoration Medical"
  description="The clinicians and physician oversight behind Restoration Medical, across medical aesthetics and infusion therapy."
>
  <section class="section-tight">
    <div class="wrap">
      <header class="page-header reveal">
        <span class="eyebrow">Our team</span>
        <h1 class="page-header__title ripple">The people who keep the standard.</h1>
        <p class="page-header__lead">
          A small, accountable team. Care is delivered by clinicians and overseen by a physician —
          the same way across every service.
        </p>
      </header>

      <div class="grid grid--cards reveal" style="margin-top:2rem">
        {
          team.map((member) => (
            <article class="card">
              <span class="card__family">{member.role}</span>
              <h3 class="card__name">{member.name}</h3>
              <p class="card__essence">{member.bio}</p>
            </article>
          ))
        }
      </div>

      <div class="advisory reveal" style="margin-top:2.5rem">
        <span class="advisory__badge" aria-hidden="true">i</span>
        <p class="advisory__body">
          <strong>Placeholder roster.</strong> Send through real names, credentials, photos, and
          bios and we’ll drop them straight in.
        </p>
      </div>
    </div>
  </section>
</Base>
