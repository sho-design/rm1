---
import Base from '../layouts/Base.astro';
---

<Base
  title="Terms of Use — Restoration Medical"
  description="The terms governing use of the Restoration Medical website."
>
  <section class="section-tight">
    <div class="wrap-narrow prose reveal">
      <span class="eyebrow">Legal</span>
      <h1 class="page-header__title">Terms of Use</h1>
      <p class="footer__fine">Last updated: June 2026 · Placeholder — review with legal counsel before launch.</p>

      <h2>No medical advice</h2>
      <p>
        Content on this website is provided for general information only and is not medical advice.
        It does not replace a consultation with a qualified clinician. Treatment suitability is
        determined only after an in-person assessment.
      </p>

      <h2>Results and expectations</h2>
      <p>
        Outcomes vary between individuals. Any descriptions of treatments or results are general and
        are not a guarantee of any particular outcome.
      </p>

      <h2>Use of the site</h2>
      <p>
        You agree to use this site lawfully and not to interfere with its operation. Content is
        owned by Restoration Medical unless otherwise noted.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms can be directed to the practice via our
        <a href="/contact">contact page</a>.
      </p>
    </div>
  </section>

  <style>
    .prose h2 {
      font-size: var(--step-2);
      margin-top: 2rem;
    }
    .prose p {
      color: var(--graphite);
      max-width: var(--measure);
    }
  </style>
</Base>
