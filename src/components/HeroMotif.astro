---
// Ambient canvas orb used in the hero — three drifting accent blooms with a
// slow specular sweep. Mirrors the motif on the division sites. Falls back to
// a soft CSS gradient when motion is reduced or canvas is unavailable.
---

<div class="hero-motif" aria-hidden="true">
  <canvas class="hero-motif__canvas"></canvas>
  <div class="hero-motif__fallback"></div>
</div>

<style>
  .hero-motif {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: 520px;
    margin-inline: auto;
  }
  .hero-motif__canvas,
  .hero-motif__fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
  }
  .hero-motif__fallback {
    background:
      radial-gradient(circle at 42% 38%, color-mix(in srgb, var(--accent-energy) 60%, white) 0%, transparent 42%),
      radial-gradient(circle at 60% 62%, color-mix(in srgb, var(--accent-injectables) 55%, white) 0%, transparent 46%),
      radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--accent-health) 40%, white) 0%, transparent 70%);
    filter: blur(6px);
    opacity: 0.9;
  }
  .hero-motif__canvas {
    opacity: 0;
    transition: opacity 0.9s var(--ease);
  }
  .hero-motif__canvas.is-live {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-motif__canvas {
      display: none;
    }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const motif = document.querySelector('.hero-motif');
  const canvas = motif?.querySelector<HTMLCanvasElement>('.hero-motif__canvas');
  if (canvas && !reduce) {
    const ctx = canvas.getContext('2d');
    const styles = getComputedStyle(document.documentElement);
    const hue = (name: string) => styles.getPropertyValue(name).trim() || '#c8a24b';
    const blooms = [
      { hue: hue('--accent-energy'), bx: 0.42, by: 0.38, r: 0.34, phase: 0 },
      { hue: hue('--accent-injectables'), bx: 0.6, by: 0.6, r: 0.3, phase: 2 },
      { hue: hue('--accent-health'), bx: 0.5, by: 0.5, r: 0.46, phase: 4 },
    ];
    let w = 0;
    let h = 0;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx && ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener('resize', resize);
    let t = 0;
    let visible = true;
    const frame = () => {
      if (!ctx || !visible) return;
      ctx.clearRect(0, 0, w, h);
      ctx.globalCompositeOperation = 'lighter';
      for (const b of blooms) {
        const dx = Math.sin(t * 0.6 + b.phase) * 0.04;
        const dy = Math.cos(t * 0.5 + b.phase) * 0.04;
        const cx = (b.bx + dx) * w;
        const cy = (b.by + dy) * h;
        const r = b.r * w * (1 + Math.sin(t * 0.8 + b.phase) * 0.08);
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
        g.addColorStop(0, b.hue + 'cc');
        g.addColorStop(0.4, b.hue + '55');
        g.addColorStop(1, b.hue + '00');
        ctx.fillStyle = g;
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';
      const sx = ((Math.sin(t * 0.4) + 1) / 2) * w;
      const sweep = ctx.createLinearGradient(sx - 60, 0, sx + 60, h);
      sweep.addColorStop(0, 'rgba(255,255,255,0)');
      sweep.addColorStop(0.5, 'rgba(255,255,255,0.14)');
      sweep.addColorStop(1, 'rgba(255,255,255,0)');
      ctx.fillStyle = sweep;
      ctx.fillRect(0, 0, w, h);
      t += 0.012;
      requestAnimationFrame(frame);
    };
    canvas.classList.add('is-live');
    requestAnimationFrame(frame);
    if ('IntersectionObserver' in window) {
      new IntersectionObserver(
        (entries) => {
          visible = entries[0].isIntersecting;
          if (visible) requestAnimationFrame(frame);
        },
        { threshold: 0.05 }
      ).observe(canvas);
    }
  }
</script>
