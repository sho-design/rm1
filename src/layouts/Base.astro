---
import '../styles/global.css';
import { institutes, type Institute } from '../data/institutes';

interface Props {
  title?: string;
  description?: string;
  /**
   * When set, the page wears that institute's world: its accent, its nav
   * identity, and a link back up to the institution. When omitted, the page
   * uses the umbrella (Restoration Medical) chrome.
   */
  institute?: Institute;
}

const {
  title = 'Restoration Medical — Refined by Medicine',
  description = 'One institution, many worlds of care. Restoration Medical brings six physician-led institutes under one roof and one clinical standard.',
  institute,
} = Astro.props;

const accentStyle = institute
  ? `--accent: var(--accent-${institute.accent}); --accent-text: var(--accent-${institute.accent}-text);`
  : undefined;

const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fcfcfd" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body style={accentStyle}>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="nav">
      <div class="wrap nav__inner">
        {
          institute ? (
            <a class="brand" href={`/${institute.slug}`} aria-label={`Restoration Medical — ${institute.formalName}`}>
              <span class="brand__name">Restoration Medical</span>
              <span class="brand__line">{institute.formalName}</span>
            </a>
          ) : (
            <a class="brand" href="/" aria-label="Restoration Medical — Refined by Medicine">
              <span class="brand__name">Restoration Medical</span>
              <span class="brand__line">Refined by Medicine</span>
            </a>
          )
        }

        <nav aria-label="Primary">
          {
            institute ? (
              <ul class="nav__links">
                <li><a class="nav__link" href={`/${institute.slug}`}>Overview</a></li>
                <li><a class="nav__link" href={`/${institute.slug}#approach`}>Approach</a></li>
                {institute.status === 'live' && institute.liveUrl && (
                  <li><a class="nav__link" href={institute.liveUrl}>Full site</a></li>
                )}
                <li><a class="nav__link" href="/#institutes">All institutes</a></li>
                <li><a class="btn btn--ghost" href="/contact">Book a consult</a></li>
              </ul>
            ) : (
              <ul class="nav__links">
                <li>
                  <button
                    class="nav__trigger"
                    aria-expanded="false"
                    aria-controls="mega-institutes"
                    data-mega="mega-institutes"
                  >
                    Institutes <span class="nav__caret" aria-hidden="true" />
                  </button>
                </li>
                <li><a class="nav__link" href="/about">About</a></li>
                <li><a class="nav__link" href="/physicians">Physicians</a></li>
                <li><a class="nav__link" href="/locations">Locations</a></li>
                <li><a class="nav__link" href="/contact">Contact</a></li>
                <li><a class="btn btn--ghost" href="/contact">Book a consult</a></li>
              </ul>
            )
          }
        </nav>

        <button class="nav__burger" aria-label="Open menu" aria-expanded="false" data-drawer-open>
          <span /><span /><span />
        </button>
      </div>

      {
        !institute && (
          <div class="mega" id="mega-institutes" role="region" aria-label="Institutes">
            <div class="wrap mega__grid">
              <div class="mega__col">
                <h4>Institutes</h4>
                {institutes.slice(0, 3).map((i) => (
                  <a class="mega__item" href={`/${i.slug}`} style={`--accent: var(--accent-${i.accent})`}>
                    <span class="mega__dot" />
                    {i.name}
                  </a>
                ))}
              </div>
              <div class="mega__col">
                <h4>&nbsp;</h4>
                {institutes.slice(3).map((i) => (
                  <a class="mega__item" href={`/${i.slug}`} style={`--accent: var(--accent-${i.accent})`}>
                    <span class="mega__dot" />
                    {i.name}
                  </a>
                ))}
              </div>
              <div class="mega__col">
                <h4>The institution</h4>
                <a class="mega__item" href="/about">About</a>
                <a class="mega__item" href="/physicians">Physicians</a>
                <a class="mega__item" href="/locations">Locations</a>
              </div>
              <div class="mega__col">
                <h4>Start here</h4>
                <a class="mega__item" href="/#institutes">Choose your journey</a>
                <a class="mega__item" href="/resources">Resources</a>
                <a class="mega__item" href="/careers">Careers</a>
                <a class="mega__item" href="/contact">Book a consult</a>
              </div>
            </div>
          </div>
        )
      }
    </header>

    <!-- Mobile drawer + scrim -->
    <div class="scrim" data-drawer-close></div>
    <aside class="drawer" aria-label="Menu">
      {
        institute ? (
          <>
            <a href={`/${institute.slug}`}>Overview</a>
            <a href={`/${institute.slug}#approach`}>Approach</a>
            {institute.status === 'live' && institute.liveUrl && <a href={institute.liveUrl}>Full site</a>}
            <a href="/#institutes">All institutes</a>
            <a class="btn" href="/contact" style="margin-top:1.2rem">Book a consult</a>
          </>
        ) : (
          <>
            <a href="/about">About</a>
            <a href="/physicians">Physicians</a>
            <a href="/locations">Locations</a>
            <a href="/resources">Resources</a>
            <a href="/careers">Careers</a>
            <details>
              <summary>Institutes</summary>
              {institutes.map((i) => (
                <a href={`/${i.slug}`}>{i.name}</a>
              ))}
            </details>
            <a class="btn" href="/contact" style="margin-top:1.2rem">Book a consult</a>
          </>
        )
      }
    </aside>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap">
        <div class="footer__grid">
          <div>
            <div class="brand">
              <span class="brand__name">Restoration Medical</span>
              <span class="brand__line">Refined by Medicine</span>
            </div>
            <p class="footer__fine" style="margin-top:1rem; max-width:34ch">
              One institution, many worlds of care — six institutes under one clinical standard.
            </p>
          </div>
          <div>
            <h4>Institutes</h4>
            {institutes.map((i) => <a class="footer__link" href={`/${i.slug}`}>{i.name}</a>)}
          </div>
          <div>
            <h4>Institution</h4>
            <a class="footer__link" href="/about">About</a>
            <a class="footer__link" href="/physicians">Physicians</a>
            <a class="footer__link" href="/locations">Locations</a>
            <a class="footer__link" href="/resources">Resources</a>
            <a class="footer__link" href="/careers">Careers</a>
          </div>
          <div>
            <h4>Visit</h4>
            <p class="footer__fine" style="margin-bottom:0.8rem">
              Restoration Medical — Main Clinic<br />000 Example Avenue, Suite 200<br />Toronto, ON<br
              />Mon–Fri 9–6 · Sat by appointment
            </p>
            <a class="footer__link" href="/contact">Book a consult</a>
          </div>
        </div>
        <div class="footer__legal">
          <span class="footer__fine">© {year} Restoration Medical. Refined by Medicine.</span>
          <span class="footer__fine">
            <a class="footer__link" style="display:inline" href="/privacy">Privacy</a> ·
            <a class="footer__link" style="display:inline" href="/terms">Terms</a> ·
            <a class="footer__link" style="display:inline" href="/accessibility">Accessibility</a>
          </span>
          <span class="footer__fine">AODA · PHIPA · CPSO</span>
        </div>
      </div>
    </footer>

    <div class="grain" aria-hidden="true"></div>

    <script src="../scripts/site.ts"></script>
  </body>
</html>
