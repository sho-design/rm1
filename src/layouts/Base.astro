---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Sets the page accent (one of the design-system accent tokens). */
  accent?: 'injectables' | 'skin' | 'energy' | 'body' | 'health' | 'clinical';
}

const {
  title = 'Restoration Medical — Refined by Medicine',
  description = 'A physician-led medical practice. Medical Aesthetics and Infusion Therapy under one clinical standard — screened first, tailored to you, and held to the evidence.',
  accent,
} = Astro.props;

const accentStyle = accent
  ? `--accent: var(--accent-${accent}); --accent-text: var(--accent-${accent}-text);`
  : undefined;

const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fcfcfd" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body style={accentStyle}>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="nav">
      <div class="wrap nav__inner">
        <a class="brand" href="/" aria-label="Restoration Medical — Refined by Medicine">
          <span class="brand__name">Restoration Medical</span>
          <span class="brand__line">Refined by Medicine</span>
        </a>
        <nav aria-label="Primary">
          <ul class="nav__links">
            <li>
              <button
                class="nav__trigger"
                aria-expanded="false"
                aria-controls="mega-services"
                data-mega="mega-services"
              >
                Services <span class="nav__caret" aria-hidden="true"></span>
              </button>
            </li>
            <li><a class="nav__link" href="/practice">The Practice</a></li>
            <li><a class="nav__link" href="/team">Our Team</a></li>
            <li><a class="nav__link" href="/contact">Contact</a></li>
            <li><a class="btn btn--ghost" href="/contact">Book a consult</a></li>
          </ul>
        </nav>
        <button class="nav__burger" aria-label="Open menu" aria-expanded="false" data-drawer-open>
          <span></span><span></span><span></span>
        </button>
      </div>

      <!-- Mega-menu: divisions + where to start -->
      <div class="mega" id="mega-services" role="region" aria-label="Services">
        <div class="wrap mega__grid">
          <div class="mega__col">
            <h4>Divisions</h4>
            <a class="mega__item" href="/medical-aesthetics" style="--accent: var(--accent-injectables)">
              <span class="mega__dot"></span>Medical Aesthetics
            </a>
            <a class="mega__item" href="/infusion-therapy" style="--accent: var(--accent-health)">
              <span class="mega__dot"></span>Infusion Therapy
            </a>
          </div>
          <div class="mega__col">
            <h4>The practice</h4>
            <a class="mega__item" href="/practice">How we practise</a>
            <a class="mega__item" href="/team">Meet the team</a>
            <a class="mega__item" href="/practice#standard">Our clinical standard</a>
          </div>
          <div class="mega__col">
            <h4>Start here</h4>
            <a class="mega__item" href="/contact">Book a consult</a>
            <a class="mega__item" href="/medical-aesthetics">Aesthetics overview</a>
            <a class="mega__item" href="/infusion-therapy">Infusion overview</a>
          </div>
        </div>
      </div>
    </header>

    <!-- Mobile drawer + scrim -->
    <div class="scrim" data-drawer-close></div>
    <aside class="drawer" aria-label="Menu">
      <a href="/medical-aesthetics">Medical Aesthetics</a>
      <a href="/infusion-therapy">Infusion Therapy</a>
      <a href="/practice">The Practice</a>
      <a href="/team">Our Team</a>
      <a href="/contact">Contact</a>
      <a class="btn" href="/contact" style="margin-top:1.2rem">Book a consult</a>
    </aside>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap">
        <div class="footer__grid">
          <div>
            <div class="brand">
              <span class="brand__name">Restoration Medical</span>
              <span class="brand__line">Refined by Medicine</span>
            </div>
            <p class="footer__fine" style="margin-top:1rem; max-width:34ch">
              One practice, one clinical standard — across medical aesthetics and infusion therapy.
            </p>
          </div>
          <div>
            <h4>Divisions</h4>
            <a class="footer__link" href="/medical-aesthetics">Medical Aesthetics</a>
            <a class="footer__link" href="/infusion-therapy">Infusion Therapy</a>
          </div>
          <div>
            <h4>Practice</h4>
            <a class="footer__link" href="/practice">The Practice</a>
            <a class="footer__link" href="/team">Our Team</a>
            <a class="footer__link" href="/contact">Contact</a>
          </div>
          <div>
            <h4>Visit</h4>
            <p class="footer__fine" style="margin-bottom:0.8rem">
              Restoration Medical — Main Clinic<br />000 Example Avenue, Suite 200<br />Toronto, ON<br
              />Mon–Fri 9–6 · Sat by appointment
            </p>
            <a class="footer__link" href="/contact">Book a consult</a>
          </div>
        </div>
        <div class="footer__legal">
          <span class="footer__fine">© {year} Restoration Medical. Refined by Medicine.</span>
          <span class="footer__fine">
            <a class="footer__link" style="display:inline" href="/privacy">Privacy</a> ·
            <a class="footer__link" style="display:inline" href="/terms">Terms</a> ·
            <a class="footer__link" style="display:inline" href="/accessibility">Accessibility</a>
          </span>
          <span class="footer__fine">AODA · PHIPA · CPSO</span>
        </div>
      </div>
    </footer>

    <div class="grain" aria-hidden="true"></div>

    <script src="../scripts/site.ts"></script>
  </body>
</html>
